---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostList from '../components/PostList.astro';
import { sortPosts } from '../utils/posts';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const recentPosts = posts.slice(0, 3);
---

<Layout>
  <section class="surface">
    <div
      class="container-custom grid gap-10 border-b py-12 rule-line desktop:grid-cols-[0.66fr_0.34fr] desktop:items-end desktop:py-20"
    >
      <div data-reveal>
        <p class="eyebrow">Agentic AI / LLM systems / agent harnesses</p>
        <h1 class="mt-5 max-w-5xl font-display text-[clamp(3rem,8vw,7rem)] leading-[0.95]">
          Marcin Skalski's Blog
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-muted">
          Notes on building agentic harnesses, working with LLMs, and understanding the engineering
          details that make autonomous software useful.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/posts/" class="btn-solid">Read posts</a>
          <a href="/about/" class="btn-outline">About</a>
        </div>
      </div>

      <figure class="portrait-block" data-reveal data-reveal-delay="120">
        <img src="/images/avatar.jpg" alt="Marcin Skalski" loading="eager" decoding="async" />
        <figcaption class="label-mono mt-4 text-muted">
          Agentic AI, LLM systems, harness design, production engineering.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="surface">
    <div class="container-custom py-12 desktop:py-20">
      <div class="mb-8 flex flex-col gap-4 tablet:flex-row tablet:items-end tablet:justify-between">
        <div>
          <p class="eyebrow">Latest writing</p>
          <h2 class="mt-3 font-display text-[clamp(2rem,5vw,4.5rem)] leading-[1]">
            Technical notes.
          </h2>
        </div>
        <a href="/posts/" class="link-mono">All posts</a>
      </div>

      <PostList posts={recentPosts} compact />
    </div>
  </section>
</Layout>

<style>
  .portrait-block {
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .portrait-block img {
    aspect-ratio: 4 / 5;
    object-fit: cover;
    width: 100%;
  }
</style>
