---
import Layout from './Layout.astro';
import { formatDate } from '../utils/posts';

interface Props {
  title: string;
  date: Date;
  description: string;
  image: string;
}

const { title, date, description, image } = Astro.props;
---

<Layout title={`${title} | Marcin Skalski`} description={description} image={image}>
  <section class="surface-soft border-b rule-line">
    <div class="container-custom grid gap-10 py-12 desktop:grid-cols-[0.7fr_0.3fr] desktop:py-20">
      <div data-reveal>
        <a href="/posts/" class="eyebrow inline-flex items-center gap-2 transition-opacity hover:opacity-70">
          <span aria-hidden="true">&lt;-</span>
          Back to posts
        </a>
        <p class="eyebrow mt-10">{formatDate(date)}</p>
        <h1 class="mt-5 max-w-5xl font-display text-[clamp(2.5rem,6vw,5.75rem)] leading-[1]">
          {title}
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted">{description}</p>
      </div>

      <figure class="article-image self-end overflow-hidden" data-reveal data-reveal-delay="120">
        <img src={image} alt="" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <section class="surface">
    <div class="container-custom py-12 desktop:py-20">
      <article class="prose mx-auto max-w-prose" data-reveal>
        <slot />
      </article>
    </div>
  </section>
</Layout>

<style>
  .article-image {
    aspect-ratio: 4 / 3;
    background: var(--bg-elevated);
  }

  .article-image img {
    height: 100%;
    width: 100%;
    object-fit: contain;
    padding: 1rem;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--text);
    font-family: var(--font-display, 'Fraunces'), serif;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin-bottom: 1rem;
    margin-top: 2.5rem;
  }

  .prose :global(h1) {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .prose :global(h2) {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .prose :global(h3) {
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
  }

  .prose :global(h4) {
    font-size: 1.25rem;
  }

  .prose :global(p) {
    color: var(--text);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .prose :global(p:first-of-type) {
    font-size: 1.22rem;
    line-height: 1.65;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .prose :global(a:hover) {
    opacity: 0.7;
  }

  .prose :global(img) {
    background: var(--bg-soft);
    margin: 2.5rem 0;
    width: 100%;
  }

  .prose :global(pre) {
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 2rem 0;
    overflow-x: auto;
    padding: 1.25rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono, 'IBM Plex Mono'), monospace;
  }

  .prose :global(:not(pre) > code) {
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    font-size: 0.9em;
    padding: 0.1rem 0.3rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--text);
    font-family: var(--font-display, 'Fraunces'), serif;
    font-size: 1.5rem;
    line-height: 1.4;
    margin: 2rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(strong) {
    font-weight: 600;
  }
</style>
