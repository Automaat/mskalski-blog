---
import type { PostEntry } from '../utils/posts';
import { formatDate, postExcerpt, postImage, postPath } from '../utils/posts';

interface Props {
  posts: PostEntry[];
  compact?: boolean;
}

const { posts, compact = false } = Astro.props;
---

<div class="grid gap-0 border-t rule-line">
  {
    posts.map((post, index) => (
      <a
        href={postPath(post.id)}
        class="post-row group"
        data-reveal
        data-reveal-delay={`${index * 60}`}
      >
        <article
          class:list={[
            'grid items-start gap-6 border-b rule-line',
            compact
              ? 'py-8 desktop:grid-cols-[0.32fr_0.68fr] desktop:gap-12'
              : 'py-10 desktop:grid-cols-[0.45fr_0.55fr] desktop:gap-16',
          ]}
        >
          <div class="post-image overflow-hidden">
            <img
              src={postImage(post.id)}
              alt=""
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </div>
          <div>
            <p class="eyebrow">{formatDate(post.data.date)}</p>
            <h2 class="mt-3 font-display text-[clamp(1.75rem,3vw,2.75rem)] leading-[1.1]">
              {post.data.title}
            </h2>
            <p class="mt-4 max-w-prose text-base leading-relaxed text-muted">{postExcerpt(post)}</p>
            <span class="label-mono mt-6 inline-flex items-center gap-2 underline underline-offset-8 transition-opacity group-hover:opacity-70">
              Read post <span aria-hidden="true">-&gt;</span>
            </span>
          </div>
        </article>
      </a>
    ))
  }
</div>

<style>
  .post-image {
    aspect-ratio: 4 / 3;
    background: var(--bg-elevated);
  }

  .post-image img {
    height: 100%;
    object-fit: contain;
    padding: 1rem;
    transition: transform 1s cubic-bezier(0.22, 0.61, 0.36, 1);
    width: 100%;
  }

  .post-row:hover .post-image img {
    transform: scale(1.04);
  }
</style>
