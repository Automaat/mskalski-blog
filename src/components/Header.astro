---
interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = [
  { href: '/posts/', label: 'Posts' },
  { href: '/public_speaking/', label: 'Speaking' },
  { href: '/about/', label: 'About' },
];
---

<header
  id="site-header"
  class="fixed left-0 top-0 z-50 w-full transition-transform duration-500 ease-editorial"
>
  <div class="border-b bg-[color:var(--bg)]/85 backdrop-blur-md rule-line">
    <nav class="container-custom flex items-center justify-between gap-6 py-4">
      <a
        href="/"
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-[color:var(--text)]"
      >
        marcin skalski
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex h-11 w-11 flex-col items-center justify-center gap-1 rounded p-2 hover:opacity-70 desktop:hidden"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="h-px w-6 bg-[color:var(--text)] transition-all"></span>
        <span class="h-px w-6 bg-[color:var(--text)] transition-all"></span>
        <span class="h-px w-6 bg-[color:var(--text)] transition-all"></span>
      </button>

      <div
        id="mobile-menu"
        class="absolute left-0 top-full hidden w-full border-b bg-[color:var(--bg)] p-6 rule-line desktop:relative desktop:flex desktop:w-auto desktop:items-center desktop:gap-10 desktop:border-0 desktop:bg-transparent desktop:p-0"
      >
        <ul
          class="flex flex-col gap-6 font-mono text-[12px] uppercase tracking-[0.14em] desktop:flex-row desktop:gap-8"
        >
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[color:var(--text)] transition-opacity hover:opacity-70"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <button
          id="theme-toggle"
          type="button"
          class="mt-6 text-[color:var(--text)] transition-opacity hover:opacity-70 desktop:mt-0"
          aria-label="Toggle dark mode"
        >
          <svg
            class="block h-[18px] w-[18px] dark:hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
            ></path>
          </svg>
          <svg
            class="hidden h-[18px] w-[18px] dark:block"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
            ></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isHidden ? 'false' : 'true');
  });

  document.addEventListener('click', (event) => {
    if (!toggle?.contains(event.target as Node) && !menu?.contains(event.target as Node)) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.focus();
    }
  });

  const header = document.getElementById('site-header');
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      if (y > 80 && y > lastY) {
        header.style.transform = 'translateY(-100%)';
      } else {
        header.style.transform = '';
      }
      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }

  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.classList.toggle('dark') ? 'dark' : 'light';
    try {
      localStorage.setItem('theme', next);
    } catch {
      /* ignore storage errors */
    }
  });
</script>
